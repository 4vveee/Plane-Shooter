import pygame
import random
import math
from pygame import mixer

mixer.init()
pygame.init()

mixer.music.load('bg.mp3')
mixer.music.play(-1)

# Tambahan clock untuk mengatur FPS
clock = pygame.time.Clock()

screen = pygame.display.set_mode((800, 600))
pygame.display.set_caption("Space Shooter Game")
icon = pygame.image.load('icon.png')
pygame.display.set_icon(icon)

background = pygame.image.load('bg.jpg')

spaceshipimg = pygame.image.load('arcade.png')

alienimg = []
alienX = []
alienY = []
alienspeedX = []
alienspeedY = []

no_of_aliens = 6

for i in range(no_of_aliens):
    alienimg.append(pygame.image.load('enemy.png'))
    alienX.append(random.randint(0, 736))
    alienY.append(random.randint(30, 150))
    alienspeedX.append(-1)
    alienspeedY.append(40)

score = 0

best_score = 0
game_over_state = False

bulletimg = pygame.image.load('bullet.png')
check = False
bulletX = 386
bulletY = 490

spaceshipX = 370
spaceshipY = 480
changeX = 0

running = True

font = pygame.font.SysFont('Times New Roman', 20)

def score_text():
    img = font.render(f'Score : {score}', True, 'white')
    screen.blit(img, (10, 10))

font_gameover = pygame.font.SysFont('Times New Roman', 40, 'bold')

def best_score_text():
    img = font.render(f'Best Score : {best_score}', True, 'white')
    screen.blit(img, (650, 10))

def gameover():
    img_gameover = font_gameover.render("GAME OVER", True, 'white')
    screen.blit(img_gameover, (270, 250))

    retry_text = font.render("Press R to Try Again", True, 'white')
    screen.blit(retry_text, (300, 320))

while running:
    screen.blit(background, (0, 0))
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

        if event.type == pygame.KEYDOWN:
            if event.key == pygame.K_LEFT:
                changeX = -3
            if event.key == pygame.K_RIGHT:
                changeX = 3
            if event.key == pygame.K_SPACE:
                bulletSound = mixer.Sound('laser.mp3')
                bulletSound.play()
                if check is False:
                    check = True
                    bulletX = spaceshipX + 16
            if event.key == pygame.K_r and game_over_state:
                score = 0
                spaceshipX = 370
                bulletY = 490
                check = False
                game_over_state = False

                for i in range(no_of_aliens):
                    alienX[i] = random.randint(0, 736)
                    alienY[i] = random.randint(30, 150)

        if event.type == pygame.KEYUP:
            changeX = 0

    spaceshipX += changeX
    if spaceshipX <= 0:
        spaceshipX = 0
    elif spaceshipX >= 736:
        spaceshipX = 736

    # Proses semua alien
    for i in range(no_of_aliens):
        if alienY[i] > 420:
            for j in range(no_of_aliens):
                alienY[j] = 2000

            if score > best_score:
                best_score = score

            game_over_state = True
            gameover()
            break

        alienX[i] += alienspeedX[i]
        if alienX[i] <= 0:
            alienspeedX[i] = 1
            alienY[i] += alienspeedY[i]
        if alienX[i] >= 736:
            alienspeedX[i] = -1
            alienY[i] += alienspeedY[i]

        # Deteksi tabrakan dengan bullet
        distance = math.sqrt(math.pow(bulletX - alienX[i], 2) + math.pow(bulletY - alienY[i], 2))
        if distance < 27:
            explosionSound = mixer.Sound('explosion.mp3')
            explosionSound.play()
            bulletY = 480
            check = False
            alienX[i] = random.randint(0, 736)
            alienY[i] = random.randint(30, 150)
            score += 1
        screen.blit(alienimg[i], (alienX[i], alienY[i]))

    if bulletY <= 0:
        bulletY = 490
        check = False
    if check:
        screen.blit(bulletimg, (bulletX, bulletY))
        bulletY -= 5

    # Gambar semua alien
    for i in range(no_of_aliens):
        screen.blit(alienimg[i], (alienX[i], alienY[i]))

    # Gambar spaceship & teks skor
    screen.blit(spaceshipimg, (spaceshipX, spaceshipY))
    score_text()
    best_score_text()

    pygame.display.update()

    # Batasi FPS
    clock.tick(150)
